# 生产环境配置
# Docker 部署使用（端口 13306 映射到容器内 3306）

# 运行环境: development | production
ENV=production

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=fund
MYSQL_PASSWORD=fund123
MYSQL_DB=fund_system

# 采集服务端口
COLLECTOR_PORT=5005

# 启动同步配置
ENABLE_STARTUP_SYNC=true
ENABLE_FUND_SYNC_SCHEDULER=true

# 日志级别
LOG_LEVEL=INFO
